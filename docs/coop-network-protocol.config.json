{
  "version": "0.1.0",
  "transport": {
    "defaultEndpoint": "ws://43.156.16.10:8080/ws",
    "fallbackEndpoint": "ws://43.156.16.10:8080/ws"
  },
  "envelope": {
    "fields": [
      "type",
      "requestId",
      "roomId",
      "senderId",
      "seq",
      "sentAt",
      "schema",
      "payload"
    ]
  },
  "spawnAnchors": {
    "host": {
      "slot": "host",
      "startPointName": "HostStartPoint",
      "leftHandAnchorName": "ScatterAnchor_007",
      "rightHandAnchorName": "ScatterAnchor_008"
    },
    "guest": {
      "slot": "guest",
      "startPointName": "GuestStartPoint",
      "leftHandAnchorName": "ScatterAnchor_001",
      "rightHandAnchorName": "ScatterAnchor_002"
    },
    "hostLeadAnchorName": "ScatterAnchor_007",
    "guestSecondAnchorName": "ScatterAnchor_001"
  },
  "sceneSpawnAnchors": [
    {
      "sceneName": "MainLevel2",
      "spawnAnchors": {
        "host": {
          "slot": "host",
          "startPointName": "HostStartPoint",
          "leftHandAnchorName": "ScatterAnchor_009",
          "rightHandAnchorName": "ScatterAnchor_007"
        },
        "guest": {
          "slot": "guest",
          "startPointName": "GuestStartPoint",
          "leftHandAnchorName": "ScatterAnchor_001",
          "rightHandAnchorName": "ScatterAnchor_002"
        },
        "hostLeadAnchorName": "ScatterAnchor_009",
        "guestSecondAnchorName": "ScatterAnchor_001"
      }
    }
  ],
  "messages": [
    {
      "type": "game.state",
      "schema": "climb-player-state.v1",
      "displayName": "Climb Player State",
      "sendMode": "interval",
      "sendRateHz": 20,
      "relay": true,
      "payloadFields": [
        { "name": "playerId", "type": "string", "required": true },
        { "name": "slot", "type": "string", "required": true },
        { "name": "climbRole", "type": "string", "required": true },
        { "name": "position", "type": "vector3", "required": true },
        { "name": "rotationY", "type": "number", "required": false },
        { "name": "movementState", "type": "string", "required": true },
        { "name": "leftHandGripId", "type": "string", "required": false },
        { "name": "rightHandGripId", "type": "string", "required": false },
        { "name": "stamina", "type": "number", "required": false },
        { "name": "isFalling", "type": "boolean", "required": false }
      ]
    },
    {
      "type": "game.event",
      "schema": "climb-event.v1",
      "displayName": "Climb Event",
      "sendMode": "event",
      "relay": true,
      "payloadFields": [
        { "name": "eventId", "type": "string", "required": true },
        { "name": "eventType", "type": "string", "required": true },
        { "name": "actorPlayerId", "type": "string", "required": true },
        { "name": "data", "type": "object", "required": false }
      ],
      "eventTypes": [
        {
          "eventType": "rivet.place",
          "displayName": "Rivet Placed",
          "description": "成功打钉后同步给远端，远端创建已部署铆钉并重算只读绳路。",
          "dataFields": [
            { "name": "rivetId", "type": "string", "required": true },
            { "name": "position", "type": "vector3", "required": true },
            { "name": "inventoryAfter", "type": "integer", "required": true },
            { "name": "ropeRevision", "type": "integer", "required": true }
          ]
        },
        {
          "eventType": "rivet.collect",
          "displayName": "Rivet Collected",
          "description": "成功回收已部署铆钉后同步给远端，远端移除铆钉、更新库存并重算只读绳路。",
          "dataFields": [
            { "name": "rivetId", "type": "string", "required": true },
            { "name": "inventoryAfter", "type": "integer", "required": true },
            { "name": "ropeRevision", "type": "integer", "required": true }
          ]
        },
        {
          "eventType": "rivet.leadSwitch",
          "displayName": "Lead Switched",
          "description": "当前领攀者成功换领后同步给远端，远端交换领攀/后攀身份但不移动玩家库存。",
          "dataFields": [
            { "name": "inventoryAfter", "type": "integer", "required": true },
            { "name": "ropeRevision", "type": "integer", "required": true }
          ]
        }
      ]
    }
  ],
  "notes": [
    "本文件定义 MainLevel MVP 客户端 game.* payload 示例。",
    "host/房主固定为上方先锋攀登者，guest/非房主固定为下方第二攀登者；该映射不随本地玩家视角变化。",
    "spawnAnchors 配置 MainLevel 的槽位出生点与左右手磁点目标：host 使用 HostStartPoint + ScatterAnchor_007/008，guest 使用 GuestStartPoint + ScatterAnchor_001/002；sceneSpawnAnchors 可为 MainLevel2 等场景覆盖同名槽位配置。",
    "game.state 是基础攀爬同步主路径，网络层应通过只读状态采样接口生成 climb-player-state.v1 payload。",
    "game.event 只用于有明确远端表现、UI 或调试需求的一次性动作。",
    "成功打钉使用 game.event / climb-event.v1 / rivet.place 同步，成功回收使用 game.event / climb-event.v1 / rivet.collect 同步，成功换领使用 game.event / climb-event.v1 / rivet.leadSwitch 同步；失败尝试不发送成功事件。",
    "修改 game.* payload 字段或发送频率不需要重新部署 relay 服务器。",
    "修改 system.* 或 room.* 控制流程可能需要修改服务器。"
  ]
}
